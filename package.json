    "scrape":    "node examples/naive-scraper.js",
    "pipeline":  "node examples/pipeline-attack.js"
  },
  "keywords": [
    "ai", "scraping", "defense", "security",
    "prompt-injection", "middleware", "proxy",
    "ctf", "anti-scraping", "llm", "canary",
